generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String         @id @default(uuid())
  tenantId     String?        @map("tenant_id")
  branchId     String?        @map("branch_id")
  name         String
  email        String         @unique
  phone        String         @unique
  passwordHash String         @map("password_hash")
  status       String         @default("ACTIVE")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  tenant       Tenant?        @relation(fields: [tenantId], references: [id])
  branch       Branch?        @relation(fields: [branchId], references: [id])
  customer     Customer?
  refreshToken RefreshToken[]
  assignedServiceOrders ServiceOrder[] @relation("MechanicServiceOrders")
  serviceOrderNotes ServiceOrderNote[]
  serviceOrderChecklists ServiceOrderChecklist[]
  stockMovements StockMovement[] @relation("StockMovementCreator")
  auditLogs    AuditLog[]
  userRoles    UserRole[]

  @@index([tenantId])
  @@index([branchId])
  @@map("users")
}

model Tenant {
  id            String               @id @default(uuid())
  name          String
  slug          String               @unique
  status        String               @default("ACTIVE")
  billingEmail  String?              @map("billing_email")
  phone         String?
  address       String?
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  branches      Branch[]
  subscriptions TenantSubscription[]
  users         User[]
  customers     Customer[]
  serviceCategories ServiceCategory[]
  serviceCatalogs ServiceCatalog[]
  sparepartCategories SparepartCategory[]
  spareparts    Sparepart[]
  stockMovements StockMovement[]
  vehicles      CustomerVehicle[]
  bookings      Booking[]
  serviceOrders ServiceOrder[]
  serviceHistory ServiceHistory[]
  invoices      Invoice[]
  payments      Payment[]

  @@index([status])
  @@map("tenants")
}

model Branch {
  id            String             @id @default(uuid())
  tenantId      String             @map("tenant_id")
  name          String
  code          String
  status        String             @default("ACTIVE")
  address       String?
  phone         String?
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  tenant        Tenant             @relation(fields: [tenantId], references: [id])
  users         User[]
  customers     Customer[]
  serviceCategories ServiceCategory[]
  serviceCatalogs ServiceCatalog[]
  sparepartCategories SparepartCategory[]
  spareparts    Sparepart[]
  stockMovements StockMovement[]
  vehicles      CustomerVehicle[]
  bookings      Booking[]
  serviceOrders ServiceOrder[]
  serviceHistory ServiceHistory[]
  invoices      Invoice[]
  payments      Payment[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([status])
  @@map("branches")
}

model SubscriptionPlan {
  id             String               @id @default(uuid())
  name           String
  code           String               @unique
  priceMonthly   Int                  @default(0) @map("price_monthly")
  maxBranches    Int?                 @map("max_branches")
  maxUsers       Int?                 @map("max_users")
  features       String?
  isActive       Boolean              @default(true) @map("is_active")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  subscriptions  TenantSubscription[]

  @@index([isActive])
  @@map("subscription_plans")
}

model TenantSubscription {
  id        String           @id @default(uuid())
  tenantId  String           @map("tenant_id")
  planId    String           @map("plan_id")
  status    String           @default("TRIAL")
  startedAt DateTime         @default(now()) @map("started_at")
  endsAt    DateTime?        @map("ends_at")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  tenant    Tenant           @relation(fields: [tenantId], references: [id])
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([tenantId])
  @@index([planId])
  @@index([status])
  @@map("tenant_subscriptions")
}

model Role {
  id        String     @id @default(uuid())
  name      String     @unique
  userRoles UserRole[]

  @@map("roles")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")
  role   Role   @relation(fields: [roleId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model Customer {
  id              String           @id @default(uuid())
  tenantId        String?          @map("tenant_id")
  branchId        String?          @map("branch_id")
  userId          String           @unique @map("user_id")
  name            String
  phone           String           @unique
  email           String           @unique
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  bookings        Booking[]
  invoices        Invoice[]
  serviceHistory  ServiceHistory[]
  serviceOrders   ServiceOrder[]
  tenant          Tenant?          @relation(fields: [tenantId], references: [id])
  branch          Branch?          @relation(fields: [branchId], references: [id])
  user            User             @relation(fields: [userId], references: [id])
  vehicles        CustomerVehicle[]

  @@index([tenantId])
  @@index([branchId])
  @@map("customers")
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenId   String    @unique @map("token_id")
  userId    String    @map("user_id")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}

model ServiceCategory {
  id        String           @id @default(uuid())
  tenantId  String?          @map("tenant_id")
  branchId  String?          @map("branch_id")
  name      String
  isActive  Boolean          @default(true) @map("is_active")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  tenant    Tenant?          @relation(fields: [tenantId], references: [id])
  branch    Branch?          @relation(fields: [branchId], references: [id])
  services  ServiceCatalog[]

  @@index([tenantId])
  @@index([branchId])
  @@map("service_categories")
}

model ServiceCatalog {
  id                       String          @id @default(uuid())
  tenantId                 String?         @map("tenant_id")
  branchId                 String?         @map("branch_id")
  categoryId               String          @map("category_id")
  name                     String
  slug                     String          @unique
  description              String
  vehicleType              String          @map("vehicle_type")
  price                    Int
  estimatedDurationMinutes Int             @map("estimated_duration_minutes")
  isActive                 Boolean         @default(true) @map("is_active")
  createdAt                DateTime        @default(now()) @map("created_at")
  updatedAt                DateTime        @updatedAt @map("updated_at")
  tenant                   Tenant?         @relation(fields: [tenantId], references: [id])
  branch                   Branch?         @relation(fields: [branchId], references: [id])
  category                 ServiceCategory @relation(fields: [categoryId], references: [id])

  @@index([tenantId])
  @@index([branchId])
  @@index([categoryId])
  @@index([vehicleType])
  @@map("service_catalogs")
}

model SparepartCategory {
  id         String      @id @default(uuid())
  tenantId   String?     @map("tenant_id")
  branchId   String?     @map("branch_id")
  name       String
  isActive   Boolean     @default(true) @map("is_active")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  tenant     Tenant?     @relation(fields: [tenantId], references: [id])
  branch     Branch?     @relation(fields: [branchId], references: [id])
  spareparts Sparepart[]

  @@index([tenantId])
  @@index([branchId])
  @@map("sparepart_categories")
}

model Sparepart {
  id          String            @id @default(uuid())
  tenantId    String?           @map("tenant_id")
  branchId    String?           @map("branch_id")
  categoryId  String            @map("category_id")
  name        String
  sku         String            @unique
  brand       String
  description String
  vehicleType String            @map("vehicle_type")
  stock       Int
  minStock    Int               @map("min_stock")
  sellPrice   Int               @map("sell_price")
  costPrice   Int               @map("cost_price")
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  tenant      Tenant?           @relation(fields: [tenantId], references: [id])
  branch      Branch?           @relation(fields: [branchId], references: [id])
  category    SparepartCategory @relation(fields: [categoryId], references: [id])
  stockMovements StockMovement[]

  @@index([tenantId])
  @@index([branchId])
  @@index([categoryId])
  @@index([brand])
  @@map("spareparts")
}

model StockMovement {
  id            String    @id @default(uuid())
  tenantId      String?   @map("tenant_id")
  branchId      String?   @map("branch_id")
  sparepartId   String    @map("sparepart_id")
  type          String
  quantity      Int
  beforeStock   Int       @map("before_stock")
  afterStock    Int       @map("after_stock")
  note          String?
  referenceType String?   @map("reference_type")
  referenceId   String?   @map("reference_id")
  createdById   String?   @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  tenant        Tenant?   @relation(fields: [tenantId], references: [id])
  branch        Branch?   @relation(fields: [branchId], references: [id])
  createdBy     User?     @relation("StockMovementCreator", fields: [createdById], references: [id])
  sparepart     Sparepart @relation(fields: [sparepartId], references: [id])

  @@index([tenantId])
  @@index([branchId])
  @@index([sparepartId])
  @@index([createdById])
  @@index([type])
  @@index([referenceType, referenceId])
  @@map("stock_movements")
}

model CustomerVehicle {
  id          String           @id @default(uuid())
  tenantId    String?          @map("tenant_id")
  branchId    String?          @map("branch_id")
  customerId  String           @map("customer_id")
  plateNumber String           @map("plate_number")
  brand       String
  model       String
  vehicleType String           @map("vehicle_type")
  year        Int?
  color       String?
  notes       String?
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  bookings    Booking[]
  tenant      Tenant?          @relation(fields: [tenantId], references: [id])
  branch      Branch?          @relation(fields: [branchId], references: [id])
  customer    Customer         @relation(fields: [customerId], references: [id])
  histories   ServiceHistory[]
  serviceOrders ServiceOrder[]

  @@index([tenantId])
  @@index([branchId])
  @@index([customerId])
  @@index([plateNumber])
  @@map("customer_vehicles")
}

model Booking {
  id          String           @id @default(uuid())
  tenantId    String?          @map("tenant_id")
  branchId    String?          @map("branch_id")
  customerId  String           @map("customer_id")
  vehicleId   String?          @map("vehicle_id")
  code        String           @unique
  serviceName String           @map("service_name")
  scheduleAt  DateTime         @map("schedule_at")
  status      String           @default("WAITING_CONFIRMATION")
  notes       String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  tenant      Tenant?          @relation(fields: [tenantId], references: [id])
  branch      Branch?          @relation(fields: [branchId], references: [id])
  customer    Customer         @relation(fields: [customerId], references: [id])
  vehicle     CustomerVehicle? @relation(fields: [vehicleId], references: [id])

  @@index([tenantId])
  @@index([branchId])
  @@index([customerId])
  @@index([vehicleId])
  @@index([status])
  @@map("bookings")
}

model ServiceOrder {
  id                  String           @id @default(uuid())
  tenantId            String?          @map("tenant_id")
  branchId            String?          @map("branch_id")
  customerId          String           @map("customer_id")
  vehicleId           String?          @map("vehicle_id")
  mechanicId          String?          @map("mechanic_id")
  code                String           @unique
  serviceName         String           @map("service_name")
  status              String           @default("IN_PROGRESS")
  currentStep         String           @map("current_step")
  checkInAt           DateTime?        @map("check_in_at")
  startedAt           DateTime?        @map("started_at")
  estimatedFinishedAt DateTime?        @map("estimated_finished_at")
  finishedAt          DateTime?        @map("finished_at")
  mileageIn           Int?             @map("mileage_in")
  customerComplaint   String?          @map("customer_complaint")
  initialDiagnosis    String?          @map("initial_diagnosis")
  totalServicePrice   Int              @default(0) @map("total_service_price")
  totalSparepartPrice Int              @default(0) @map("total_sparepart_price")
  grandTotal          Int              @default(0) @map("grand_total")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  tenant              Tenant?          @relation(fields: [tenantId], references: [id])
  branch              Branch?          @relation(fields: [branchId], references: [id])
  customer            Customer         @relation(fields: [customerId], references: [id])
  mechanic            User?            @relation("MechanicServiceOrders", fields: [mechanicId], references: [id])
  vehicle             CustomerVehicle? @relation(fields: [vehicleId], references: [id])
  notes               ServiceOrderNote[]
  photos              ServiceOrderPhoto[]
  checklists          ServiceOrderChecklist[]
  serviceItems        ServiceOrderServiceItem[]
  sparepartItems      ServiceOrderSparepartItem[]
  invoice             Invoice?

  @@index([tenantId])
  @@index([branchId])
  @@index([customerId])
  @@index([vehicleId])
  @@index([mechanicId])
  @@index([status])
  @@map("service_orders")
}

model ServiceOrderServiceItem {
  id             String       @id @default(uuid())
  serviceOrderId String       @map("service_order_id")
  serviceCatalogId String?    @map("service_catalog_id")
  name           String
  price          Int
  quantity       Int          @default(1)
  subtotal       Int
  createdAt      DateTime     @default(now()) @map("created_at")
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id])

  @@index([serviceOrderId])
  @@index([serviceCatalogId])
  @@map("service_order_service_items")
}

model ServiceOrderSparepartItem {
  id             String       @id @default(uuid())
  serviceOrderId String       @map("service_order_id")
  sparepartId    String?      @map("sparepart_id")
  name           String
  price          Int
  quantity       Int
  subtotal       Int
  createdAt      DateTime     @default(now()) @map("created_at")
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id])

  @@index([serviceOrderId])
  @@index([sparepartId])
  @@map("service_order_sparepart_items")
}

model ServiceOrderNote {
  id             String       @id @default(uuid())
  serviceOrderId String       @map("service_order_id")
  userId         String       @map("user_id")
  note           String
  visibility     String       @default("INTERNAL")
  createdAt      DateTime     @default(now()) @map("created_at")
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@index([serviceOrderId])
  @@index([userId])
  @@index([visibility])
  @@map("service_order_notes")
}

model ServiceOrderPhoto {
  id             String       @id @default(uuid())
  serviceOrderId String       @map("service_order_id")
  url            String
  caption        String?
  visibility     String       @default("CUSTOMER_VISIBLE")
  createdAt      DateTime     @default(now()) @map("created_at")
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id])

  @@index([serviceOrderId])
  @@index([visibility])
  @@map("service_order_photos")
}

model ServiceOrderChecklist {
  id             String       @id @default(uuid())
  serviceOrderId String       @map("service_order_id")
  userId         String       @map("user_id")
  title          String
  isDone         Boolean      @default(false) @map("is_done")
  note           String?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@index([serviceOrderId])
  @@index([userId])
  @@index([isDone])
  @@map("service_order_checklists")
}

model ServiceHistory {
  id          String           @id @default(uuid())
  tenantId    String?          @map("tenant_id")
  branchId    String?          @map("branch_id")
  customerId  String           @map("customer_id")
  vehicleId   String?          @map("vehicle_id")
  serviceName String           @map("service_name")
  serviceDate DateTime         @map("service_date")
  odometer    Int?
  totalPrice  Int              @map("total_price")
  notes       String?
  createdAt   DateTime         @default(now()) @map("created_at")
  tenant      Tenant?          @relation(fields: [tenantId], references: [id])
  branch      Branch?          @relation(fields: [branchId], references: [id])
  customer    Customer         @relation(fields: [customerId], references: [id])
  vehicle     CustomerVehicle? @relation(fields: [vehicleId], references: [id])

  @@index([tenantId])
  @@index([branchId])
  @@index([customerId])
  @@index([vehicleId])
  @@map("service_history")
}

model Invoice {
  id             String        @id @default(uuid())
  tenantId       String?       @map("tenant_id")
  branchId       String?       @map("branch_id")
  customerId     String        @map("customer_id")
  serviceOrderId String?       @unique @map("service_order_id")
  invoiceNumber  String        @unique @map("invoice_number")
  status         String        @default("UNPAID")
  issuedAt       DateTime      @map("issued_at")
  dueAt          DateTime?     @map("due_at")
  totalAmount    Int           @map("total_amount")
  paidAmount     Int           @default(0) @map("paid_amount")
  pdfUrl         String?       @map("pdf_url")
  paidAt         DateTime?     @map("paid_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  tenant         Tenant?       @relation(fields: [tenantId], references: [id])
  branch         Branch?       @relation(fields: [branchId], references: [id])
  customer       Customer      @relation(fields: [customerId], references: [id])
  serviceOrder   ServiceOrder? @relation(fields: [serviceOrderId], references: [id])
  items          InvoiceItem[]
  payments       Payment[]

  @@index([tenantId])
  @@index([branchId])
  @@index([customerId])
  @@index([status])
  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String   @map("invoice_id")
  type        String
  name        String
  quantity    Int      @default(1)
  price       Int
  subtotal    Int
  createdAt   DateTime @default(now()) @map("created_at")
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@index([type])
  @@map("invoice_items")
}

model Payment {
  id               String   @id @default(uuid())
  tenantId         String?  @map("tenant_id")
  branchId         String?  @map("branch_id")
  invoiceId         String   @map("invoice_id")
  paymentNumber     String   @unique @map("payment_number")
  amount            Int
  method            String
  status            String   @default("CONFIRMED")
  paidAt            DateTime @map("paid_at")
  referenceNumber   String?  @map("reference_number")
  note              String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  tenant            Tenant?  @relation(fields: [tenantId], references: [id])
  branch            Branch?  @relation(fields: [branchId], references: [id])
  invoice           Invoice  @relation(fields: [invoiceId], references: [id])

  @@index([tenantId])
  @@index([branchId])
  @@index([invoiceId])
  @@index([status])
  @@map("payments")
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?  @map("actor_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  requestId  String?  @map("request_id")
  createdAt  DateTime @default(now()) @map("created_at")
  actor      User?    @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
