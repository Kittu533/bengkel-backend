generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String         @id @default(uuid())
  name         String
  email        String         @unique
  phone        String         @unique
  passwordHash String         @map("password_hash")
  status       String         @default("ACTIVE")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  customer     Customer?
  refreshToken RefreshToken[]
  userRoles    UserRole[]

  @@map("users")
}

model Role {
  id        String     @id @default(uuid())
  name      String     @unique
  userRoles UserRole[]

  @@map("roles")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")
  role   Role   @relation(fields: [roleId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model Customer {
  id              String           @id @default(uuid())
  userId          String           @unique @map("user_id")
  name            String
  phone           String           @unique
  email           String           @unique
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  bookings        Booking[]
  invoices        Invoice[]
  serviceHistory  ServiceHistory[]
  serviceOrders   ServiceOrder[]
  user            User             @relation(fields: [userId], references: [id])
  vehicles        CustomerVehicle[]

  @@map("customers")
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenId   String    @unique @map("token_id")
  userId    String    @map("user_id")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}

model ServiceCategory {
  id        String           @id @default(uuid())
  name      String
  isActive  Boolean          @default(true) @map("is_active")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  services  ServiceCatalog[]

  @@map("service_categories")
}

model ServiceCatalog {
  id                       String          @id @default(uuid())
  categoryId               String          @map("category_id")
  name                     String
  slug                     String          @unique
  description              String
  vehicleType              String          @map("vehicle_type")
  price                    Int
  estimatedDurationMinutes Int             @map("estimated_duration_minutes")
  isActive                 Boolean         @default(true) @map("is_active")
  createdAt                DateTime        @default(now()) @map("created_at")
  updatedAt                DateTime        @updatedAt @map("updated_at")
  category                 ServiceCategory @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([vehicleType])
  @@map("service_catalogs")
}

model SparepartCategory {
  id         String      @id @default(uuid())
  name       String
  isActive   Boolean     @default(true) @map("is_active")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  spareparts Sparepart[]

  @@map("sparepart_categories")
}

model Sparepart {
  id          String            @id @default(uuid())
  categoryId  String            @map("category_id")
  name        String
  sku         String            @unique
  brand       String
  description String
  vehicleType String            @map("vehicle_type")
  stock       Int
  minStock    Int               @map("min_stock")
  sellPrice   Int               @map("sell_price")
  costPrice   Int               @map("cost_price")
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  category    SparepartCategory @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([brand])
  @@map("spareparts")
}

model CustomerVehicle {
  id          String           @id @default(uuid())
  customerId  String           @map("customer_id")
  plateNumber String           @map("plate_number")
  brand       String
  model       String
  vehicleType String           @map("vehicle_type")
  year        Int?
  color       String?
  notes       String?
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  bookings    Booking[]
  customer    Customer         @relation(fields: [customerId], references: [id])
  histories   ServiceHistory[]
  serviceOrders ServiceOrder[]

  @@index([customerId])
  @@index([plateNumber])
  @@map("customer_vehicles")
}

model Booking {
  id          String           @id @default(uuid())
  customerId  String           @map("customer_id")
  vehicleId   String?          @map("vehicle_id")
  code        String           @unique
  serviceName String           @map("service_name")
  scheduleAt  DateTime         @map("schedule_at")
  status      String           @default("WAITING_CONFIRMATION")
  notes       String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  customer    Customer         @relation(fields: [customerId], references: [id])
  vehicle     CustomerVehicle? @relation(fields: [vehicleId], references: [id])

  @@index([customerId])
  @@index([vehicleId])
  @@index([status])
  @@map("bookings")
}

model ServiceOrder {
  id                  String           @id @default(uuid())
  customerId          String           @map("customer_id")
  vehicleId           String?          @map("vehicle_id")
  code                String           @unique
  serviceName         String           @map("service_name")
  status              String           @default("IN_PROGRESS")
  currentStep         String           @map("current_step")
  startedAt           DateTime?        @map("started_at")
  estimatedFinishedAt DateTime?        @map("estimated_finished_at")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  customer            Customer         @relation(fields: [customerId], references: [id])
  vehicle             CustomerVehicle? @relation(fields: [vehicleId], references: [id])

  @@index([customerId])
  @@index([vehicleId])
  @@index([status])
  @@map("service_orders")
}

model ServiceHistory {
  id          String           @id @default(uuid())
  customerId  String           @map("customer_id")
  vehicleId   String?          @map("vehicle_id")
  serviceName String           @map("service_name")
  serviceDate DateTime         @map("service_date")
  odometer    Int?
  totalPrice  Int              @map("total_price")
  notes       String?
  createdAt   DateTime         @default(now()) @map("created_at")
  customer    Customer         @relation(fields: [customerId], references: [id])
  vehicle     CustomerVehicle? @relation(fields: [vehicleId], references: [id])

  @@index([customerId])
  @@index([vehicleId])
  @@map("service_history")
}

model Invoice {
  id            String    @id @default(uuid())
  customerId    String    @map("customer_id")
  invoiceNumber String    @unique @map("invoice_number")
  status        String    @default("UNPAID")
  issuedAt      DateTime  @map("issued_at")
  dueAt         DateTime? @map("due_at")
  totalAmount   Int       @map("total_amount")
  paidAt        DateTime? @map("paid_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  customer      Customer  @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([status])
  @@map("invoices")
}
